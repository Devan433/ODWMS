rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admins collection ────────────────────────────────────────
    match /admins/{uid} {
      allow get:    if request.auth != null;
      allow list:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if isAdmin() || (request.auth != null && request.auth.uid == uid);
      allow delete: if isAdmin();
    }

    // ── Admin helper function ───────────────────────────────────
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── Collector helper function ───────────────────────────────
    function isCollector() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/collectors/$(request.auth.uid));
    }

    // ── Admin-only collections (unchanged) ──────────────────────
    match /collectors/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == docId);
    }
    match /smart_bins/{docId}         { allow read, write: if isAdmin(); }
    match /normal_bins/{docId}        { allow read, write: if isAdmin(); }
    match /routes/{docId}             { allow read, write: if isAdmin(); }
    match /requests/{docId}           { allow read, write: if isAdmin(); }
    match /resolved_requests/{docId}  { allow read, write: if isAdmin(); }
    match /adminStats/{docId}         { allow read, write: if isAdmin(); }

    // ── Shared collections (admin + user app) ───────────────────

    // Users — admins can access all, regular users can access own doc
    match /users/{docId} {
      allow read, write: if isAdmin();
      allow read, write: if request.auth != null && request.auth.uid == docId;
      // Collectors can read user docs (address access controlled at app level)
      allow read: if isCollector();

      // Allow users to manage their own addresses sub-collection
      match /addresses/{addressId} {
        allow read, write: if request.auth != null && request.auth.uid == docId;
        // Assigned collector can read user's address
        allow read: if isCollector();
      }
    }

    // Transactions — admins can access all, users can create & read own
    match /transactions/{docId} {
      allow read, write: if isAdmin();
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Subscriptions — admins can access all, users can manage own
    match /subscriptions/{docId} {
      allow read, write: if isAdmin();
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ── User App collections ────────────────────────────────────

    // Pickup requests — admins + collectors can access all, users can create & manage own
    match /pickupRequests/{docId} {
      allow read, write: if isAdmin();
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update: if request.auth != null && resource.data.userId == request.auth.uid;
      // ── Collector app: collectors can read all & update assigned pickups ──
      allow read: if isCollector();
      allow update: if isCollector();
    }

    // Smart bins (user-facing) — users can read/write own bins
    match /bins/{docId} {
      allow read, write: if isAdmin();
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Marketplace — any authenticated user can browse, users manage own listings
    match /marketplace/{docId} {
      allow read, write: if isAdmin();
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Market rates — read-only for users
    match /marketRates/{docId} {
      allow read, write: if isAdmin();
      allow read: if request.auth != null;
    }

    // Subscription plans — read-only for users
    match /subscriptionPlans/{docId} {
      allow read, write: if isAdmin();
      allow read: if request.auth != null;
    }

    // ── Auto-Assignment Collections ─────────────────────────────

    // collectorAssign — written by admin dashboard automation engine
    // Collectors can read & update their own assignment doc (for real-time listening)
    match /collectorAssign/{assignId} {
      allow read, write: if isAdmin();
      allow read: if isCollector() && resource.data.collectorId == request.auth.uid;
      allow update: if isCollector() && resource.data.collectorId == request.auth.uid;
    }

    // collectorLocations — written by collectors, read by any authenticated user (for live tracking)
    match /collectorLocations/{collectorId} {
      allow read, write: if isAdmin();
      allow read: if request.auth != null;  // Users need this for live tracking
      // Collectors can write their own location
      allow write: if request.auth != null && request.auth.uid == collectorId;
    }

    // earnings — collectors view their own, admins manage payouts
    match /earnings/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if isAdmin();
      
      match /transactions/{transactionId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if isAdmin(); 
      }
    }

    // assignmentArchive — admin only (post-completion permanent record)
    match /assignmentArchive/{assignId} {
      allow read, write: if isAdmin();
    }
  }
}