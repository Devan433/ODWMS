# .gitignore for ODWMS (On-Demand Waste Management System)

# --- SECURITY: Firebase Secrets ---
# Since this is a Public repo, we MUST ignore these files.
google-services.json
GoogleService-Info.plist
firebase_options.dart
sha_keys.txt
*.jks
*.keystore

# --- Flutter/Dart ---
.dart_tool/
.packages
.pub-cache/
.pub/
build/
*.part
*.js_
*.js.deps
*.js.map
*.info

# --- Logs ---
*.log
npm-debug.log*

# --- Android/iOS junk ---
.gradle/
local.properties
ios/Pods/
ios/.symlinks/

# --- IDEs ---
.vscode/
.idea/
.DS_Store
